{%- macro pointer_handle(library, handle, param, state) %}
    args[{{ state.counter }}] = {{ param.name }} != NULL ? jerry_create_number(pointer_handles_get_or_add{{ library.name }}_{{ param.pointer_handle }}((void*) {{ param.name }})) : jerry_create_null();
{%- endmacro %}

{%- macro number(library, handle, param, state) %}
    args[{{ state.counter }}] = jerry_create_number({{ param.name }});
{%- endmacro %}

{%- macro string(library, handle, param, state) %}
    args[{{ state.counter }}] = jerry_create_string((const jerry_char_t*) {{ param.name }});
{%- endmacro %}

{%- macro byte_array(library, handle, param, state) %}
    {%- if param.length_parameter not in handle.parameters -%}
        {% raise "library '" ~ library.name ~ "', function handle'" ~ handle.name ~ "', parameter '" ~ param.name ~ "': length parameter '" ~ param.length_parameter ~ "' does not exist as parameter" %}
    {%- endif -%}
    {%- if not handle.parameters[param.length_parameter].is_number() -%}
        {% raise "library '" ~ library.name ~ "', function handle'" ~ handle.name ~ "', parameter '" ~ param.name ~ "': length parameter '" ~ param.length_parameter ~ "' is not a number" %}
    {%- endif %}
    if ({{ param.name }} != NULL) {
        args[{{ state.counter }}] = jerry_create_string_sz((const jerry_char_t*) {{ param.name }}, {{ param.length_parameter }});
    } else {
        args[{{ state.counter }}] = jerry_create_null();
    }
{%- endmacro %}