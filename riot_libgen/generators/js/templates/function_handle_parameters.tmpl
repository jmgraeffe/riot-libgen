{%- macro struct(library, handle, param, dest) -%}
    {{ dest }} = jerry_create_object();
    {%- for field in library.structs[param.struct].fields.values() %}
        {%- if field.is_array() %}
    {{ field._element_parameter.type }}* {{ param.name }}_{{ field.name }} = {{ param.name }}.{{ field.name }};
            {% set manipulated_field = namespace(name=param.name ~ '_' ~ field.name, _element_parameter=field._element_parameter, array_size=field.array_size) %}
    jerry_value_t {{ array(library, function, manipulated_field, 'field_value_' ~ field.name) }}
        {%- elif field.is_pointer_handle() %}
    {{ field.type }} {{ param.name }}_{{ field.name }} = {{ param.name }}.{{ field.name }};
            {% set manipulated_field = namespace(name=param.name ~ '_' ~ field.name) %}
    jerry_value_t {{ pointer_handle(library, function, manipulated_field, 'field_value_' ~ field.name) }}
        {%- elif field.is_number() %}
    {{ field.type }} {{ param.name }}_{{ field.name }} = {{ param.name }}.{{ field.name }};
            {% set manipulated_field = namespace(name=param.name ~ '_' ~ field.name) %}
    jerry_value_t {{ number(library, function, manipulated_field, 'field_value_' ~ field.name) }}
        {%- elif field.is_string() %}
    {{ field.type }} {{ param.name }}_{{ field.name }} = {{ param.name }}.{{ field.name }};
            {% set manipulated_field = namespace(name=param.name ~ '_' ~ field.name) %}
    jerry_value_t {{ string(library, function, manipulated_field, 'field_value_' ~ field.name) }}
        {%- elif field.is_byte_array() -%}
    {{ field.type }} {{ param.name }}_{{ field.name }} = {{ param.name }}.{{ field.name }};
            {% set manipulated_field = namespace(name=param.name ~ '_' ~ field.name) %}
    jerry_value_t {{ byte_array(library, function, manipulated_field, 'field_value_' ~ field.name) }}
        {%- else %}
            {% raise "library '" ~ library.name ~ "', function handle'" ~ handle.name ~ "', parameter '" ~ param.name ~ "': unsupported type '" ~ field.type ~ "' for struct field" %}
        {%- endif %}
    jerry_value_t field_property_name_{{ field.name }} = jerry_create_string((const jerry_char_t*) ("{{ field.name }}"));
    jerry_set_property({{ dest }}, field_property_name_{{ field.name }}, field_value_{{ field.name }});
    jerry_release_value(field_property_name_{{ field.name }});
    jerry_release_value(field_value_{{ field.name }});
    {%- endfor %}
{%- endmacro %}

{%- macro array(library, handle, param, dest) -%}
    {{ dest }} = jerry_create_array({{ param.array_size }});
    for (uint32_t i = 0; i < (uint32_t) ({{ param.array_size }}); ++i) {
        {# TODO this might fail with pointer handles, doesn't it #}
        {{ param._element_parameter.type }} {{ param.name }}_elem = {{ param.name }}[i];
    {%- if param._element_parameter.is_pointer_handle() %}
        {% set elem_parameter = namespace(name=param.name ~ '_elem') %}
        {{ pointer_handle(library, handle, elem_parameter, 'jerry_value_t value_' ~ param.name) }}
    {%- elif param._element_parameter.is_number() %}
        {% set elem_parameter = namespace(name=param.name ~ '_elem') %}
        {{ number(library, handle, elem_parameter, 'jerry_value_t value_' ~ param.name) }}
    {%- elif param._element_parameter.is_string() %}
        {% set elem_parameter = namespace(name=param.name ~ '_elem') %}
        {{ string_byte_array(library, handle, elem_parameter, 'jerry_value_t value_' ~ param.name) }}
    {%- else %}
        {% raise "library '" ~ library.name ~ "', function handle'" ~ handle.name ~ "', parameter '" ~ param.name ~ "': element type '" ~ param._element_parameter.type ~ "' of array not supported" %}
    {% endif %}
        jerry_set_property_by_index({{ dest }}, i, value_{{ param.name }});
        jerry_release_value(value_{{ param.name }});
    }
{%- endmacro %}

{%- macro pointer_handle(library, handle, param, dest) -%}
    {{ dest }} = {{ param.name }} != NULL ? jerry_create_number(pointer_handles_get_or_add{{ library.name }}_{{ param.pointer_handle }}((void*) {{ param.name }})) : jerry_create_null();
{%- endmacro %}

{%- macro number(library, handle, param, dest) -%}
    {{ dest }} = jerry_create_number({{ param.name }});
{%- endmacro %}

{%- macro string(library, handle, param, dest) -%}
    {{ dest }} = jerry_create_string((const jerry_char_t*) {{ param.name }});
{%- endmacro %}

{%- macro byte_array(library, handle, param, dest) -%}
    {%- if param.length_parameter not in handle.parameters -%}
        {% raise "library '" ~ library.name ~ "', function handle'" ~ handle.name ~ "', parameter '" ~ param.name ~ "': length parameter '" ~ param.length_parameter ~ "' does not exist as parameter" %}
    {%- endif -%}
    {%- if not handle.parameters[param.length_parameter].is_number() -%}
        {% raise "library '" ~ library.name ~ "', function handle'" ~ handle.name ~ "', parameter '" ~ param.name ~ "': length parameter '" ~ param.length_parameter ~ "' is not a number" %}
    {%- endif %}
    if ({{ param.name }} != NULL) {
        {{ dest }} = jerry_create_string_sz((const jerry_char_t*) {{ param.name }}, {{ param.length_parameter }});
    } else {
        {{ dest }} = jerry_create_null();
    }
{%- endmacro %}